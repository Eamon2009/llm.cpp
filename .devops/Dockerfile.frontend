# =============================================================================
# Quadtrix.cpp — React/Vite Frontend
# Stage 1: node builder  →  Stage 2: nginx static serve
# Mirrors llama.cpp's approach: build once, serve thin
# =============================================================================

# ── Stage 1: Build ────────────────────────────────────────────────────────────
FROM node:20-alpine AS builder

WORKDIR /app

# Layer-cache: install deps before copying source
COPY frontend/package.json frontend/package-lock.json ./
RUN npm ci --prefer-offline

# Build args for runtime API URL injection
ARG VITE_API_BASE_URL=http://localhost:3001
ENV VITE_API_BASE_URL=${VITE_API_BASE_URL}

COPY frontend/ ./

RUN npm run build

# ── Stage 2: Nginx runtime ────────────────────────────────────────────────────
FROM nginx:1.27-alpine AS runtime

LABEL org.opencontainers.image.title="Quadtrix Frontend"
LABEL org.opencontainers.image.description="React chat UI served via Nginx"
LABEL org.opencontainers.image.source="https://github.com/Eamon2009/Quadtrix.cpp"

# Remove default config
RUN rm /etc/nginx/conf.d/default.conf

# Custom nginx config with SPA routing + API proxy
COPY docker/nginx.conf /etc/nginx/conf.d/quadtrix.conf

COPY --from=builder /app/dist /usr/share/nginx/html

EXPOSE 80

HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
    CMD wget -qO- http://localhost/ || exit 1

CMD ["nginx", "-g", "daemon off;"]
